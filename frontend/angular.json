{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "ai-construction-bid-analyzer-frontend": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/ai-construction-bid-analyzer-frontend",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "assets": ["src/favicon.ico", "src/assets"],
            "styles": ["src/styles.css"],
            "scripts": []
          },
          "configurations": {
            "production": {"optimization": true, "outputHashing": "all"},
            "development": {"optimization": false, "sourceMap": true}
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {"buildTarget": "ai-construction-bid-analyzer-frontend:build:production"},
            "development": {"buildTarget": "ai-construction-bid-analyzer-frontend:build:development"}
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
